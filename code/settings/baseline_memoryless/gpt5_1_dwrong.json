{
  "experiment_name": "memoryless_gpt5_1_dwrong",
  "description": "Memoryless baseline (within-game memory across rounds only; no memory across games): openai/gpt-5.1, D always incorrect; 10 independent games.",
  "game_settings": {
    "num_players": 4,
    "num_games": 10,
    "max_rounds_per_game": null,
    "question_sets": [
      "basic_arithmetic.csv"
    ]
  },
  "player_models": [
    "openai/gpt-5.1",
    "openai/gpt-5.1",
    "openai/gpt-5.1",
    "dummy"
  ],
  "reasoning_effort_config": {
    "_comment": "high reasoning for GPT agents, none for dummy",
    "A": "high",
    "B": "high",
    "C": "high",
    "D": "none"
  },
  "memory_config": {
    "A": {
      "mode": "current_game_only",
      "window": 100,
      "reflection": "none",
      "persist_across_games": false
    },
    "B": {
      "mode": "current_game_only",
      "window": 100,
      "reflection": "none",
      "persist_across_games": false
    },
    "C": {
      "mode": "current_game_only",
      "window": 100,
      "reflection": "none",
      "persist_across_games": false
    },
    "D": {
      "mode": "current_game_only",
      "window": 100,
      "reflection": "none",
      "persist_across_games": true
    }
  },
  "dummy_config": {
    "D": {
      "correctness_list": [
        false,
        false,
        false,
        false,
        false,
        false,
        false,
        false,
        false,
        false
      ]
    }
  },
  "output_settings": {
    "save_logs": true,
    "log_directory": "game_logs",
    "print_progress": true
  }
}