{
  "experiment_name": "memoryless_sonnet_dcorrect",
  "description": "Memoryless baseline (within-game memory across rounds only; no memory across games): anthropic:claude-sonnet-4-6, D always correct; 10 independent games.",
  "game_settings": {
    "num_players": 4,
    "num_games": 10,
    "max_rounds_per_game": null,
    "question_sets": [
      "basic_arithmetic.csv"
    ]
  },
  "player_models": [
    "anthropic:claude-sonnet-4-6",
    "anthropic:claude-sonnet-4-6",
    "anthropic:claude-sonnet-4-6",
    "dummy"
  ],
  "reasoning_effort_config": {
    "_comment": "Claude adaptive mode (Anthropic's recommended default for 4.6+); model decides whether to think based on request complexity",
    "A": "adaptive",
    "B": "adaptive",
    "C": "adaptive",
    "D": "none"
  },
  "memory_config": {
    "A": {
      "mode": "current_game_only",
      "window": 100,
      "reflection": "none",
      "persist_across_games": false
    },
    "B": {
      "mode": "current_game_only",
      "window": 100,
      "reflection": "none",
      "persist_across_games": false
    },
    "C": {
      "mode": "current_game_only",
      "window": 100,
      "reflection": "none",
      "persist_across_games": false
    },
    "D": {
      "mode": "current_game_only",
      "window": 100,
      "reflection": "none",
      "persist_across_games": true
    }
  },
  "dummy_config": {
    "D": {
      "correctness_list": [
        true,
        true,
        true,
        true,
        true,
        true,
        true,
        true,
        true,
        true
      ]
    }
  },
  "output_settings": {
    "save_logs": true,
    "log_directory": "game_logs",
    "print_progress": true
  }
}